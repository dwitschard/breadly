# .env.example — template for local backend development
# Copy to .env and fill in the required values.
# Do NOT commit .env (git-ignored). This file IS committed.

# ── Required ──────────────────────────────────────────────────────────────────

MONGODB_CONNECTION_STRING=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=<app>

# Cognito OIDC issuer — format: https://cognito-idp.<region>.amazonaws.com/<user-pool-id>
# Use the preview pool's issuer URL for local development (same pool used by preview deploys).
COGNITO_ISSUER=https://cognito-idp.eu-central-1.amazonaws.com/<user-pool-id>

# Cognito app client ID (localhost-specific client from the preview pool).
# Run `terraform output cognito_localhost_client_id` in infrastructure/aws/preview/gateway/
# to get the correct value.
COGNITO_CLIENT_ID=<localhost-client-id>

# Required for the /api/profile endpoint to return display names and email.
# Without this, fetchUserInfo() returns null and profile fields are empty.
# Use the preview pool's hosted UI domain for local development.
COGNITO_USERINFO_URL=https://preview.auth.appdock.ch/oauth2/userInfo

# ── Optional (defaults shown) ─────────────────────────────────────────────────

# PORT=3000
# ENV_NAME=local
# AWS_REGION=eu-central-1
# APP_URL=http://localhost:4200
# SES_SENDER_EMAIL=floete-argon.8h@icloud.com
# SES_CONFIGURATION_SET=
# SCHEDULER_GROUP_NAME=breadly-schedules
# SCHEDULER_ROLE_ARN=
# API_GATEWAY_ENDPOINT=
# PREVIEW_PATH_PREFIX=
