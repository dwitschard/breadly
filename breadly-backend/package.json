{
  "name": "breadly-backend",
  "version": "1.0.0",
  "description": "",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "dev": "tsx --env-file=./src/.env src/server.ts",
    "generate-api": "npm run --prefix ../breadly-api lint && openapi-typescript ../breadly-api/openapi.yaml -o src/app/generated/api/index.ts --root-types --root-types-no-schema-prefix",
    "build": "npm run generate-api && tsc -p tsconfig.build.json",
    "test": "jest --no-cache --detectOpenHandles",
    "test:ci": "jest --no-cache --detectOpenHandles --forceExit",
    "lint": "eslint . --fix"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "mongodb": "^7.1.0",
    "pino": "^10.3.1",
    "pino-http": "^11.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.2.1",
    "@types/pino-http": "^5.8.4",
    "@types/supertest": "^6.0.3",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "eslint-plugin-jest": "^29.15.0",
    "globals": "^17.4.0",
    "jest": "^30.2.0",
    "mongodb-memory-server": "^11.0.1",
    "nodemon": "^3.1.11",
    "openapi-typescript": "^7.13.0",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
