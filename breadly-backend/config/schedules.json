{
   "defaults": {
     "retry_policy": {
       "maximum_retry_attempts": 3,
       "maximum_event_age_in_seconds": 3600
     }
   },
   "schedules": [
    {
      "name": "daily-greeting",
      "description": "Daily greeting email sent to all users at 7am Zurich time",
      "enabled": true,
      "retry_policy": null,
      "schedule_expression": "cron(0 7 * * ? *)",
      "timezone": "Europe/Zurich",
      "target": {
        "method": "POST",
        "path": "/api/internal/reminders/batch"
      },
      "payload": {
        "type": "greeting",
        "template": "greeting",
        "subject": "Good morning from Breadly!",
        "userIds": [
          "bootsleute.ansammlung.2b@icloud.com"
        ]
      }
    }
  ]
}
