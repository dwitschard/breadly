{
  "name": "breadly-api",
  "version": "1.0.0",
  "description": "OpenAPI contract for the Breadly application",
  "type": "module",
  "main": "./generated/openapi.ts",
  "types": "./generated/openapi.ts",
  "scripts": {
    "lint": "redocly lint openapi.yaml",
    "validate": "redocly lint openapi.yaml --format=summary",
    "generate": "openapi-typescript openapi.yaml -o ./generated/openapi.ts"
  },
  "devDependencies": {
    "@redocly/cli": "^1.34.4",
    "openapi-typescript": "^7.8.0",
    "typescript": "^5.9.3"
  }
}
